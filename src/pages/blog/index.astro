---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FloatingWhatsApp from '../../components/FloatingWhatsApp.astro';

const posts = (await getCollection('blog')).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout
  title="手機保養攻略 | MonCity Blog"
  description="手機保養知識、換電池攻略、螢幕更換教學。MonCity 深水埗手機服務專家分享實用資訊。"
  pathname="/blog/"
>
  <Header />
  <FloatingWhatsApp />
  <main id="main" class="section">
    <div class="container">
      <h1 class="section-title">手機保養攻略</h1>
      <p class="section-subtitle">實用知識，幫你了解手機保養大小事</p>
      <div class="blog-grid">
        {posts.map(post => (
          <a href={`/blog/${post.id}/`} class="blog-card">
            <div class="blog-card-body">
              <time class="blog-date" datetime={post.data.date.toISOString().slice(0, 10)}>
                {post.data.date.toLocaleDateString('zh-HK', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <h2 class="blog-card-title">{post.data.title}</h2>
              <p class="blog-card-desc">{post.data.description}</p>
              <span class="blog-read-more">閱讀全文 →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 28px;
  }
  .blog-card {
    background: var(--paper);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
    color: var(--ink);
  }
  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    color: var(--ink);
  }
  .blog-card-body { padding: 28px; }
  .blog-date { font-size: 0.85rem; color: var(--ink-soft); }
  .blog-card-title {
    font-size: 1.3rem;
    font-weight: 700;
    margin: 8px 0 12px;
    line-height: 1.4;
  }
  .blog-card-desc {
    color: var(--ink-muted);
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 16px;
  }
  .blog-read-more {
    color: var(--primary);
    font-weight: 600;
    font-size: 0.9rem;
  }

  @media (max-width: 768px) {
    .blog-grid { grid-template-columns: 1fr; }
  }
</style>
