---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FloatingWhatsApp from '../../components/FloatingWhatsApp.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={`${post.data.title} | MonCity`}
  description={post.data.description}
  pathname={`/blog/${post.id}/`}
>
  <Header />
  <FloatingWhatsApp />
  <main id="main" class="section">
    <div class="container blog-post">
      <a href="/blog/" class="back-link">← 返回文章列表</a>
      <article>
        <header class="post-header">
          <time class="post-date" datetime={post.data.date.toISOString().slice(0, 10)}>
            {post.data.date.toLocaleDateString('zh-HK', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          <h1 class="post-title">{post.data.title}</h1>
        </header>
        <div class="post-content">
          <Content />
        </div>
      </article>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .blog-post { max-width: 760px; }
  .back-link {
    display: inline-block;
    color: var(--primary);
    font-size: 0.9rem;
    font-weight: 500;
    margin-bottom: 24px;
  }
  .back-link:hover { color: var(--primary-dark); }
  .post-date { font-size: 0.9rem; color: var(--ink-soft); }
  .post-title {
    font-size: 2rem;
    font-weight: 800;
    margin: 8px 0 40px;
    line-height: 1.3;
  }
  .post-content :global(h2) {
    font-size: 1.4rem;
    font-weight: 700;
    margin: 36px 0 12px;
  }
  .post-content :global(h3) {
    font-size: 1.15rem;
    font-weight: 600;
    margin: 28px 0 8px;
  }
  .post-content :global(p) {
    color: var(--ink-muted);
    line-height: 1.9;
    margin-bottom: 16px;
  }
  .post-content :global(ul), .post-content :global(ol) {
    padding-left: 24px;
    margin-bottom: 16px;
  }
  .post-content :global(li) {
    color: var(--ink-muted);
    line-height: 1.8;
    margin-bottom: 6px;
  }
  .post-content :global(strong) { color: var(--ink); }
  .post-content :global(a) { color: var(--primary); text-decoration: underline; }
  .post-content :global(a:hover) { color: var(--primary-dark); }
  .post-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 20px;
  }
  .post-content :global(th), .post-content :global(td) {
    border: 1px solid var(--border);
    padding: 10px 14px;
    text-align: left;
  }
  .post-content :global(th) {
    background: var(--paper-alt);
    font-weight: 600;
  }
  .post-content :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 32px 0;
  }

  @media (max-width: 768px) {
    .post-title { font-size: 1.5rem; }
  }
</style>
