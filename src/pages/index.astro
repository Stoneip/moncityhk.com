---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Stats from '../components/Stats.astro';
import Services from '../components/Services.astro';
import Process from '../components/Process.astro';
import Reviews from '../components/Reviews.astro';
import FAQ from '../components/FAQ.astro';
import Contact from '../components/Contact.astro';
import GiftBanner from '../components/GiftBanner.astro';
import Footer from '../components/Footer.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';
---

<BaseLayout
  title="深水埗手機零件店 - MonCity 換Mon城 | iPhone、Samsung、華為零件、SSD 硬碟批發"
  description="深水埗手機零件店，提供 iPhone、iPad、Samsung、華為、小米、Pixel 等手機零件 — 前螢幕玻璃、螢幕總成、後蓋、電池、Face ID 模組、排線，另設 SSD 固態硬碟、外接硬碟、儲存配件。原裝及副廠選擇，門市現貨，批發零售歡迎。"
>
  <Header />
  <FloatingWhatsApp />
  <main id="main">
    <Hero />
    <Stats />
    <Services />
    <Reviews />
    <Process />
    <FAQ />
    <GiftBanner />
    <Contact />
  </main>
  <Footer />
</BaseLayout>
