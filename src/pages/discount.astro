---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const googleMapsUrl = 'https://maps.app.goo.gl/rtoUcQDWsXnkjuTSA';

// Google OAuth Client ID — 喺 Google Cloud Console > APIs & Services > Credentials 建立
// 類型：Web application
// Authorized JavaScript origins: https://moncityhk.com, http://localhost:4321
const GOOGLE_CLIENT_ID = import.meta.env.PUBLIC_GOOGLE_CLIENT_ID || '';
---

<BaseLayout
  title="領取神秘禮物 - MonCity 換Mon城"
  description="完成 MonCity 服務後，登入即可領取神秘禮物！"
>
  <Header />
  <main id="main">
    <section class="gift-page">
      <div class="container gift-container">

        <div id="login-section" class="gift-card">
          <div class="gift-emoji">🎁</div>
          <h1 class="gift-title">領取你嘅神秘禮物</h1>
          <p class="gift-desc">完成 MonCity 服務後，用 Google 帳戶登入即可領取！</p>
          <div id="google-signin-btn" class="signin-container"></div>
          <p class="gift-note">我哋只會記錄你嘅名稱同電郵，用作服務追蹤。</p>
        </div>

        <div id="reward-section" class="gift-card" style="display:none;">
          <div class="gift-emoji">🎉</div>
          <h1 class="gift-title">恭喜你！</h1>
          <div class="customer-row">
            <img id="customer-avatar" src="" alt="" class="customer-avatar" />
            <span id="customer-name" class="customer-name"></span>
          </div>
          <div class="reward-badge">
            <div class="reward-label">🎁 神秘禮物</div>
            <p class="reward-instruction">請向店員出示此畫面領取</p>
            <p class="reward-date" id="reward-date"></p>
          </div>
          <div class="review-divider"></div>
          <h2 class="review-heading">順便幫我哋留個評價？🙏</h2>
          <p class="review-desc">你嘅好評係對我哋最大嘅支持</p>
          <a href={googleMapsUrl} class="btn btn-primary btn-review" target="_blank" rel="noopener" id="review-from-gift-btn">
            ⭐ 去 Google Maps 留評
          </a>
        </div>

        <div id="error-section" class="gift-card" style="display:none;">
          <div class="gift-emoji">⚠️</div>
          <h1 class="gift-title">登入功能未設定</h1>
          <p class="gift-desc">請聯絡店員協助。</p>
        </div>

      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script src="https://accounts.google.com/gsi/client" async defer></script>
<script is:inline define:vars={{ GOOGLE_CLIENT_ID }}>
  function decodeJwt(token) {
    var base64Url = token.split('.')[1];
    var base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');
    var jsonPayload = decodeURIComponent(
      atob(base64).split('').map(function(c) {
        return '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2);
      }).join('')
    );
    return JSON.parse(jsonPayload);
  }

  window.handleCredentialResponse = function(response) {
    var payload = decodeJwt(response.credential);

    document.getElementById('login-section').style.display = 'none';
    document.getElementById('reward-section').style.display = 'block';

    document.getElementById('customer-name').textContent = payload.name;
    var avatar = document.getElementById('customer-avatar');
    if (payload.picture) {
      avatar.src = payload.picture;
      avatar.alt = payload.name;
    } else {
      avatar.style.display = 'none';
    }

    var now = new Date();
    var dateStr = now.getFullYear() + '-' +
      String(now.getMonth() + 1).padStart(2, '0') + '-' +
      String(now.getDate()).padStart(2, '0') + ' ' +
      String(now.getHours()).padStart(2, '0') + ':' +
      String(now.getMinutes()).padStart(2, '0');
    document.getElementById('reward-date').textContent = dateStr;

    if (typeof gtag !== 'undefined') {
      gtag('set', 'user_data', { 'email': payload.email });
      gtag('event', 'discount_claimed', {
        'event_category': 'conversion',
        'event_label': 'google_login_gift'
      });
    }
  };

  var storedCredential = sessionStorage.getItem('mc_credential');
  if (storedCredential) {
    sessionStorage.removeItem('mc_credential');
    window.handleCredentialResponse({ credential: storedCredential });
  }

  function initGoogleSignIn() {
    if (storedCredential) return;
    if (!GOOGLE_CLIENT_ID) {
      document.getElementById('login-section').style.display = 'none';
      document.getElementById('error-section').style.display = 'block';
      return;
    }
    if (typeof google === 'undefined' || !google.accounts) {
      setTimeout(initGoogleSignIn, 200);
      return;
    }
    google.accounts.id.initialize({
      client_id: GOOGLE_CLIENT_ID,
      callback: window.handleCredentialResponse
    });
    google.accounts.id.renderButton(
      document.getElementById('google-signin-btn'),
      { theme: 'outline', size: 'large', text: 'signin_with', locale: 'zh-TW', width: 300 }
    );
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initGoogleSignIn);
  } else {
    initGoogleSignIn();
  }

  document.addEventListener('DOMContentLoaded', function() {
    var reviewBtn = document.getElementById('review-from-gift-btn');
    if (reviewBtn) {
      reviewBtn.addEventListener('click', function() {
        if (typeof gtag !== 'undefined') {
          gtag('event', 'review_from_gift', {
            'event_category': 'social',
            'event_label': 'gift_page_review'
          });
        }
      });
    }
  });
</script>

<style>
  .gift-page {
    padding: 80px 0;
    min-height: calc(100vh - var(--header-h));
    background: linear-gradient(135deg, var(--primary-light) 0%, var(--paper) 100%);
  }
  .gift-container {
    max-width: 520px;
  }
  .gift-card {
    background: var(--paper);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    padding: 48px 32px;
    text-align: center;
  }
  .gift-emoji {
    font-size: 4rem;
    margin-bottom: 16px;
  }
  .gift-title {
    font-size: 1.8rem;
    font-weight: 800;
    margin-bottom: 12px;
  }
  .gift-desc {
    color: var(--ink-muted);
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: 32px;
  }
  .signin-container {
    display: flex;
    justify-content: center;
    margin-bottom: 20px;
  }
  .gift-note {
    font-size: 0.8rem;
    color: var(--ink-soft);
  }

  .customer-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 24px;
  }
  .customer-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 2px solid var(--border);
  }
  .customer-name {
    font-size: 1.2rem;
    font-weight: 700;
  }

  .reward-badge {
    background: var(--primary-light);
    border: 2px solid var(--primary);
    border-radius: var(--radius-lg);
    padding: 24px;
    margin-bottom: 32px;
  }
  .reward-label {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--primary);
    margin-bottom: 8px;
  }
  .reward-instruction {
    font-size: 1rem;
    color: var(--ink-muted);
    margin-bottom: 8px;
  }
  .reward-date {
    font-size: 0.85rem;
    color: var(--ink-soft);
    font-family: monospace;
  }

  .review-divider {
    height: 1px;
    background: var(--border);
    margin-bottom: 24px;
  }
  .review-heading {
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 8px;
  }
  .review-desc {
    color: var(--ink-muted);
    margin-bottom: 20px;
  }
  .btn-review {
    width: 100%;
    justify-content: center;
  }

  @media (max-width: 768px) {
    .gift-page { padding: 48px 0; }
    .gift-card { padding: 32px 20px; }
    .gift-title { font-size: 1.5rem; }
    .gift-emoji { font-size: 3rem; }
  }
</style>
