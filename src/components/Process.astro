---
const steps = [
  { num: '1', title: 'WhatsApp 查詢', desc: '透過 WhatsApp 描述手機問題，我哋會即時回覆初步報價。',
    svg: '<svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 26l2-6a10 10 0 1 1 4 4z"/><path d="M12 14h8M12 18h5"/></svg>' },
  { num: '2', title: '現場檢測', desc: '帶手機到深水埗深之都門市，技師即場檢測確認維修方案。',
    svg: '<svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="14" cy="14" r="8"/><line x1="20" y1="20" x2="28" y2="28"/></svg>' },
  { num: '3', title: '即場維修', desc: '確認報價後即場維修，大部分問題即日完成交還。',
    svg: '<svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="16" cy="16" r="12"/><path d="M10 16l4 4 8-8"/></svg>' },
];
---

<section class="section" id="process">
  <div class="container">
    <h2 class="section-title">維修流程</h2>
    <p class="section-subtitle">簡單三步，快捷維修</p>
    <div class="process-steps">
      {steps.map((step, i) => (
        <div class="step">
          <div class="step-num">{step.num}</div>
          <span class="step-icon" set:html={step.svg} />
          <h3 class="step-title">{step.title}</h3>
          <p class="step-desc">{step.desc}</p>
          {i < steps.length - 1 && <div class="step-arrow" aria-hidden="true">→</div>}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .process-steps {
    display: flex;
    align-items: flex-start;
    gap: 24px;
    position: relative;
  }
  .step {
    flex: 1;
    text-align: center;
    position: relative;
  }
  .step-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: var(--primary);
    color: #fff;
    font-weight: 700;
    font-size: 1.2rem;
    border-radius: 50%;
    margin-bottom: 16px;
  }
  .step-icon { width: 36px; height: 36px; color: var(--primary); margin: 0 auto 12px; }
  .step-icon :global(svg) { width: 100%; height: 100%; }
  .step-title { font-size: 1.1rem; font-weight: 700; margin-bottom: 8px; }
  .step-desc { color: var(--ink-muted); font-size: 0.95rem; }
  .step-arrow {
    position: absolute;
    right: -24px;
    top: 24px;
    font-size: 1.5rem;
    color: var(--primary);
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .process-steps { flex-direction: column; align-items: center; }
    .step-arrow { display: none; }
    .step { max-width: 400px; }
  }
</style>
