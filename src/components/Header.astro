---
const navLinks = [
  { label: '服務', href: '/#services' },
  { label: '流程', href: '/#process' },
  { label: 'FAQ', href: '/#faq' },
  { label: '聯絡我哋', href: '/#contact' },
];
---

<header class="header">
  <div class="container header-inner">
    <a href="/" class="logo" aria-label="MonCity 手機維修 首頁">
      <span class="logo-icon">📱</span>
      <span class="logo-text">MonCity <span class="logo-sub">手機維修</span></span>
    </a>
    <nav class="nav" id="nav" aria-label="主要導航">
      {navLinks.map(link => (
        <a href={link.href} class="nav-link">{link.label}</a>
      ))}
      <a href="https://wa.me/85269960711" class="btn btn-primary btn-sm" target="_blank" rel="noopener">
        WhatsApp 預約
      </a>
    </nav>
    <button class="hamburger" id="hamburger" aria-label="開啟選單" aria-expanded="false" aria-controls="nav">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
    height: var(--header-h);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 700;
    font-size: 1.2rem;
    color: var(--ink);
  }
  .logo:hover { color: var(--primary); }
  .logo-icon { font-size: 1.5rem; }
  .logo-sub { color: var(--ink-muted); font-weight: 400; font-size: 0.9rem; }
  .nav {
    display: flex;
    align-items: center;
    gap: 24px;
  }
  .nav-link {
    color: var(--ink-muted);
    font-weight: 500;
    font-size: 0.95rem;
    transition: color 0.2s;
  }
  .nav-link:hover { color: var(--primary); }
  .btn-sm { padding: 8px 20px; font-size: 0.9rem; }
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
  }
  .hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--ink);
    transition: transform 0.3s, opacity 0.3s;
  }

  @media (max-width: 768px) {
    .hamburger { display: flex; }
    .nav {
      display: none;
      position: absolute;
      top: var(--header-h);
      left: 0;
      right: 0;
      background: var(--paper);
      flex-direction: column;
      padding: 20px;
      gap: 16px;
      border-bottom: 1px solid var(--border);
      box-shadow: var(--shadow-lg);
    }
    .nav.open { display: flex; }
    .nav-link { font-size: 1.1rem; }
  }
</style>

<script>
  const hamburger = document.getElementById('hamburger');
  const nav = document.getElementById('nav');
  hamburger?.addEventListener('click', () => {
    const open = nav?.classList.toggle('open');
    hamburger.setAttribute('aria-expanded', String(open));
  });
  nav?.querySelectorAll('.nav-link').forEach(link => {
    link.addEventListener('click', () => {
      nav.classList.remove('open');
      hamburger?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
