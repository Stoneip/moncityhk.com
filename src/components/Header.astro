---
const navLinks = [
  { label: '服務', href: '/#services' },
  { label: '流程', href: '/#process' },
  { label: '評價', href: '/#reviews' },
  { label: 'FAQ', href: '/#faq' },
  { label: '聯絡', href: '/#contact' },
  { label: 'Blog', href: '/blog/' },
];
---

<header class="header">
  <div class="container header-inner">
    <a href="/" class="logo" aria-label="MonCity 手機維修 首頁">
      <img src="/logo.png" alt="MonCity" class="logo-img" width="36" height="36" />
      <span class="logo-text">MonCity <span class="logo-sub">手機維修</span></span>
    </a>
    <nav class="nav" id="nav" aria-label="主要導航">
      {navLinks.map(link => (
        <a href={link.href} class="nav-link">{link.label}</a>
      ))}
      <a href="https://wa.me/85269960711?text=%E4%BD%A0%E5%A5%BD%EF%BC%8C%E6%88%91%E6%83%B3%E8%A9%A2%E5%95%8F%E6%89%8B%E6%A9%9F%E7%B6%AD%E4%BF%AE%E5%A0%B1%E5%83%B9%E3%80%82%E6%88%91%E7%9A%84%E5%9E%8B%E8%99%9F%E6%98%AF%EF%BC%9A" class="btn btn-whatsapp btn-sm" target="_blank" rel="noopener"
        onclick="gtag('event','whatsapp_click',{event_category:'contact',event_label:'header'})">
        WhatsApp 預約
      </a>
    </nav>
    <button class="hamburger" id="hamburger" aria-label="開啟選單" aria-expanded="false" aria-controls="nav">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(204,0,0,0.97);
    backdrop-filter: blur(8px);
    border-bottom: none;
    height: var(--header-h);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 700;
    font-size: 1.2rem;
    color: #fff;
  }
  .logo:hover { color: #ffe0e0; }
  .logo-img { border-radius: 50%; background: #fff; }
  .logo-sub { color: rgba(255,255,255,0.85); font-weight: 400; font-size: 0.9rem; }
  .nav {
    display: flex;
    align-items: center;
    gap: 24px;
  }
  .nav-link {
    color: rgba(255,255,255,0.9);
    font-weight: 500;
    font-size: 0.95rem;
    transition: color 0.2s;
  }
  .nav-link:hover { color: #fff; }
  .btn-sm { padding: 8px 20px; font-size: 0.9rem; }
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
  }
  .hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background: #fff;
    transition: transform 0.3s, opacity 0.3s;
  }

  @media (max-width: 768px) {
    .hamburger { display: flex; }
    .nav {
      display: none;
      position: absolute;
      top: var(--header-h);
      left: 0;
      right: 0;
      background: var(--primary);
      flex-direction: column;
      padding: 20px;
      gap: 16px;
      border-bottom: none;
      box-shadow: var(--shadow-lg);
    }
    .nav.open { display: flex; }
    .nav-link { font-size: 1.1rem; }
  }
</style>

<script>
  const hamburger = document.getElementById('hamburger');
  const nav = document.getElementById('nav');
  hamburger?.addEventListener('click', () => {
    const open = nav?.classList.toggle('open');
    hamburger.setAttribute('aria-expanded', String(open));
  });
  nav?.querySelectorAll('.nav-link').forEach(link => {
    link.addEventListener('click', () => {
      nav.classList.remove('open');
      hamburger?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
