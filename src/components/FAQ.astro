---
const faqs = [
  {
    q: '零件係原裝定副廠？',
    a: '兩種都有。iPhone、Samsung、華為等主流型號螢幕總成同電池，提供原裝及副廠選擇；副廠價錢平大約 30-50%。落單前可以指定，到店亦可以即場揀。',
  },
  {
    q: '零件有冇保養？',
    a: '所有零件提供保養。螢幕總成、電池一般 30 至 90 日保養（視乎品項），保留單據可以憑單跟進。詳細條款歡迎 WhatsApp 查詢。',
  },
  {
    q: '可唔可以批發？最少訂幾多件？',
    a: '可以。同行業界客戶批發歡迎查詢，常見型號（iPhone 螢幕、Samsung S 系列、Redmi 等）有現貨。批發無最低訂量，量大有額外折扣。',
  },
  {
    q: '我搵唔到我部手機嘅零件，仲有冇貨？',
    a: '價目表只列常見型號。其他品牌（Realme、Vivo、Tecno、新出機型等）部份型號可以訂貨，一般 1-3 個工作日到貨。WhatsApp 報型號查詢即可。',
  },
  {
    q: '可以幫我裝埋嗎？',
    a: '可以。買零件後可即場代裝，代裝係另計收費，視乎型號同零件複雜程度。歡迎 WhatsApp 一齊查詢價錢。',
  },
  {
    q: 'SSD 硬碟有冇貨？支援咩規格？',
    a: '有。門市備有 SSD 固態硬碟（NVMe M.2 / SATA 2.5"）、外接 USB / Type-C 硬碟、記憶卡、USB 隨身碟，常見品牌包括 Samsung、Western Digital、Kingston、Crucial 等。容量由 256GB 至 4TB 都揀到。型號 / 容量歡迎 WhatsApp 報嚟查現貨同價錢。',
  },
  {
    q: '付款方式？',
    a: '現金、轉數快 FPS、八達通、信用卡、支付寶、微信支付均可。批發大額單可以開單。',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<section class="section section-alt" id="faq">
  <div class="container">
    <h2 class="section-title">常見問題</h2>
    <p class="section-subtitle">買零件之前你可能想知道嘅嘢</p>
    <div class="faq-list">
      {faqs.map(f => (
        <details class="faq-item">
          <summary class="faq-q">{f.q}</summary>
          <div class="faq-a">{f.a}</div>
        </details>
      ))}
    </div>
  </div>
</section>
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<style>
  .faq-list { max-width: 800px; margin: 0 auto; }
  .faq-item {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    margin-bottom: 12px;
    background: var(--paper);
    overflow: hidden;
  }
  .faq-q {
    padding: 20px 24px;
    font-weight: 600;
    font-size: 1.05rem;
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .faq-q::after {
    content: '+';
    font-size: 1.4rem;
    color: var(--primary);
    font-weight: 700;
    flex-shrink: 0;
    transition: transform 0.2s;
  }
  .faq-item[open] .faq-q::after {
    content: '−';
  }
  .faq-q::-webkit-details-marker { display: none; }
  .faq-a {
    padding: 0 24px 20px;
    color: var(--ink-muted);
    line-height: 1.8;
  }
</style>
