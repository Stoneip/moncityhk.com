---
const services = [
  {
    title: '更換螢幕玻璃',
    desc: '提供各型號手機螢幕玻璃面板，現場即時更換安裝，恢復如新外觀。',
    svg: '<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="12" y="4" width="24" height="40" rx="3"/><line x1="18" y1="4" x2="30" y2="4"/><line x1="16" y1="12" x2="28" y2="28"/><line x1="28" y1="14" x2="18" y2="26"/><circle cx="24" cy="39" r="2"/></svg>',
  },
  {
    title: '更換鏡頭組件',
    desc: '供應 iPhone、Samsung 等原裝及副廠鏡頭組件，即場安裝更換。',
    svg: '<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="24" cy="24" r="10"/><circle cx="24" cy="24" r="4"/><path d="M14 8h20l4 6h4v26H6V14h4z"/></svg>',
  },
  {
    title: '更換液晶螢幕',
    desc: '提供全新液晶螢幕總成，包安裝更換，還原出廠顯示效果。',
    svg: '<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="8" y="6" width="32" height="36" rx="2"/><rect x="12" y="10" width="24" height="22" rx="1"/><line x1="20" y1="38" x2="28" y2="38"/><line x1="12" y1="16" x2="36" y2="16" stroke-dasharray="2 3"/></svg>',
  },
  {
    title: '更換按鍵零件',
    desc: '備有 Home 鍵、開關機鍵等零件，現場安裝更換。',
    svg: '<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="12" y="4" width="24" height="40" rx="3"/><circle cx="24" cy="38" r="4"/><circle cx="24" cy="38" r="1.5" fill="currentColor"/><rect x="16" y="10" width="16" height="20" rx="1"/></svg>',
  },
  {
    title: '更換電池',
    desc: '提供全新手機電池，即場安裝更換，延長手機使用壽命。',
    svg: '<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="8" y="14" width="32" height="20" rx="3"/><rect x="40" y="20" width="4" height="8" rx="1"/><line x1="20" y1="24" x2="28" y2="24"/><line x1="24" y1="20" x2="24" y2="28"/></svg>',
  },
  {
    title: '更換充電位組件',
    desc: '供應充電接口零件，現場安裝更換，歡迎到店查詢。',
    svg: '<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="24" cy="28" r="14"/><path d="M18 18l-4-4M30 18l4-4"/><line x1="24" y1="22" x2="24" y2="28"/><line x1="24" y1="28" x2="30" y2="24"/><circle cx="24" cy="28" r="2" fill="currentColor"/></svg>',
  },
];
---

<section class="section section-alt" id="services">
  <div class="container">
    <h2 class="section-title">手機零件及更換服務</h2>
    <p class="section-subtitle">提供各品牌手機零件，門市即場安裝更換</p>
    <div class="services-grid">
      {services.map(s => (
        <div class="service-card">
          <div class="service-icon" set:html={s.svg} />
          <h3 class="service-title">{s.title}</h3>
          <p class="service-desc">{s.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .service-card {
    background: var(--paper);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 32px 24px;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .service-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }
  .service-icon {
    width: 48px;
    height: 48px;
    color: var(--primary);
    margin-bottom: 16px;
  }
  .service-icon :global(svg) {
    width: 100%;
    height: 100%;
  }
  .service-title { font-size: 1.2rem; font-weight: 700; margin-bottom: 8px; }
  .service-desc { color: var(--ink-muted); font-size: 0.95rem; line-height: 1.7; }

  @media (max-width: 768px) {
    .services-grid { grid-template-columns: 1fr; }
  }
  @media (min-width: 769px) and (max-width: 1024px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
