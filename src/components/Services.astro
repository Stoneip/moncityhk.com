---
const categories = [
  {
    title: 'iPhone 零件',
    desc: 'iPhone 5 至 17 Pro Max 全代零件：前螢幕玻璃、螢幕總成、後蓋、Face ID、電池。',
    href: '/parts/#brand-iphone',
    svg: '<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="12" y="4" width="24" height="40" rx="3"/><line x1="18" y1="4" x2="30" y2="4"/><circle cx="24" cy="39" r="2"/></svg>',
  },
  {
    title: 'Samsung 零件',
    desc: 'Galaxy S / Note / A / M / J / Fold / Flip 系列螢幕、外屏、內屏、排線。',
    href: '/parts/#brand-samsung',
    svg: '<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="10" y="6" width="28" height="36" rx="4"/><line x1="18" y1="38" x2="30" y2="38"/></svg>',
  },
  {
    title: 'iPad / Watch 零件',
    desc: 'iPad / iPad Pro / Mini / Apple Watch 全系列螢幕及電池零件。',
    href: '/parts/#brand-ipad',
    svg: '<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="8" width="36" height="32" rx="3"/><circle cx="24" cy="36" r="1.5" fill="currentColor"/></svg>',
  },
  {
    title: '華為 / 小米 零件',
    desc: 'Huawei Mate / P、Honor、Xiaomi、Redmi、Pocophone 零件。',
    href: '/parts/#brand-huawei',
    svg: '<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="24" cy="24" r="14"/><path d="M14 24h20M24 14v20"/></svg>',
  },
  {
    title: '電池零件',
    desc: 'iPhone、Apple Watch、Android 各品牌電池，原裝及副廠選擇。',
    href: '/parts/#brand-iphone',
    svg: '<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="8" y="14" width="32" height="20" rx="3"/><rect x="40" y="20" width="4" height="8" rx="1"/><line x1="14" y1="24" x2="20" y2="24"/><line x1="24" y1="24" x2="30" y2="24"/></svg>',
  },
  {
    title: '配件 / 其他',
    desc: '手機殼、保護貼、Sony、Pixel、OnePlus、Motorola、Surface 零件。',
    href: '/parts/#brand-sony',
    svg: '<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 14h32v22H8z"/><path d="M16 14v-4h16v4"/><circle cx="24" cy="25" r="4"/></svg>',
  },
];
---

<section class="section section-alt" id="services">
  <div class="container">
    <h2 class="section-title">手機零件分類</h2>
    <p class="section-subtitle">深水埗門市現貨，按品牌瀏覽完整目錄</p>
    <div class="services-grid">
      {categories.map(c => (
        <a class="service-card" href={c.href}>
          <div class="service-icon" set:html={c.svg} />
          <h3 class="service-title">{c.title}</h3>
          <p class="service-desc">{c.desc}</p>
          <span class="service-link">查看價目 →</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .service-card {
    display: block;
    background: var(--paper);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 32px 24px;
    transition: box-shadow 0.2s, transform 0.2s, border-color 0.2s;
    color: var(--ink);
    text-decoration: none;
  }
  .service-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
    border-color: var(--primary);
    color: var(--ink);
  }
  .service-icon {
    width: 48px;
    height: 48px;
    color: var(--primary);
    margin-bottom: 16px;
  }
  .service-icon :global(svg) {
    width: 100%;
    height: 100%;
  }
  .service-title { font-size: 1.2rem; font-weight: 700; margin-bottom: 8px; }
  .service-desc { color: var(--ink-muted); font-size: 0.95rem; line-height: 1.7; margin-bottom: 12px; }
  .service-link { color: var(--primary); font-weight: 600; font-size: 0.95rem; }

  @media (max-width: 768px) {
    .services-grid { grid-template-columns: 1fr; }
  }
  @media (min-width: 769px) and (max-width: 1024px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
