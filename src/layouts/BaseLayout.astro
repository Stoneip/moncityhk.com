---
interface Props {
  title: string;
  description: string;
  pathname?: string;
}

const { title, description, pathname = '' } = Astro.props;
const canonicalURL = new URL(pathname, Astro.site);
const siteName = 'MonCity 換Mon城';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'MobilePhoneStore',
  '@id': 'https://moncityhk.com/#business',
  name: 'MONCITY 換Mon城',
  alternateName: 'MonCity 手機零件店',
  description: '香港深水埗手機零件店，售賣 iPhone、Samsung、華為、小米、Pixel 等手機零件 — 前螢幕玻璃、螢幕總成、後蓋、電池、Face ID 模組、排線。原裝及副廠選擇，門市現貨，批發零售。',
  url: 'https://moncityhk.com',
  telephone: '+852-6996-0711',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '長沙灣道226號深之都1樓230號鋪',
    addressLocality: '深水埗',
    addressRegion: '九龍',
    addressCountry: 'HK',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 22.3314439,
    longitude: 114.1618173,
  },
  areaServed: { '@type': 'City', name: 'Hong Kong' },
  priceRange: '$$',
  image: 'https://moncityhk.com/og-share.png',
  sameAs: [
    'https://www.facebook.com/moncityhk/',
    'https://maps.app.goo.gl/rtoUcQDWsXnkjuTSA',
  ],
};

const webSiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteName,
  url: 'https://moncityhk.com',
};
---

<!doctype html>
<html lang="zh-HK">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="preconnect" href="https://www.google-analytics.com" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="zh_HK" />
    <meta property="og:image" content="https://moncityhk.com/og-share.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://moncityhk.com/og-share.png" />

    <link rel="alternate" hreflang="zh-HK" href={canonicalURL} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL} />

    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webSiteSchema)} />

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-7B53J3CMY2"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-7B53J3CMY2');
      gtag('config', 'AW-17523347184');
    </script>
    <script is:inline>
      gtag('event', 'conversion', {'send_to': 'AW-17523347184/v-d8CK2vibAcEPCd5KNB'});
      document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('a[href*="wa.me"], a[href*="whatsapp.com"]').forEach(function(element) {
          element.addEventListener('click', function() {
            if (typeof gtag !== 'undefined') {
              gtag('event', 'whatsapp_click', {
                'event_category': 'contact',
                'event_label': 'whatsapp_conversion'
              });
              gtag('event', 'conversion', {'send_to': 'AW-17523347184/haKUCMiZorAcEPCd5KNB'});
            }
          });
        });
        document.querySelectorAll('a[href^="tel:"]').forEach(function(element) {
          element.addEventListener('click', function() {
            if (typeof gtag !== 'undefined') {
              gtag('event', 'phone_click', {
                'event_category': 'contact',
                'event_label': 'phone_conversion'
              });
              gtag('event', 'conversion', {'send_to': 'AW-17523347184/Y5SFCIKiibAcEPCd5KNB'});
            }
          });
        });
        document.querySelectorAll('a[href*="mailto"]').forEach(function(element) {
          element.addEventListener('click', function() {
            if (typeof gtag !== 'undefined') {
              gtag('event', 'conversion', {'send_to': 'AW-17523347184/9YmACJSribAcEPCd5KNB'});
            }
          });
        });
      });
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">跳至主要內容</a>
    <slot />
  </body>
</html>
